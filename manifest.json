{
  "manifest_version": 3,
  "name": "EchoParrot",
  "version": "1.9.7",
  "description": "現在のタブの音声を録音してWebMファイルとして保存します — EchoParrot",
  "permissions": [
    "tabCapture",
    "tabs",
    "scripting",
    "storage",
    "windows"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://api.github.com/*"
  ]
}
